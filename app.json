{
  "expo": {
    "name": "שליטה",
    "slug": "leave-it",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leaveit.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.leaveit.app"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "leave-it",
    "experiments": {
      "typedRoutes": true
    }
  }
}
